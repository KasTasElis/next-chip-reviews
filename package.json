{
  "name": "next-chip-review",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "supabase:generate:types:linked": "supabase gen types typescript --linked > supabase/generated.types.ts",
    "supabase:generate:types:local": "supabase gen types typescript --local > supabase/generated.types.ts",
    "supabase:db:pull": "supabase db pull",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:seed": "tsx --env-file=.env.local supabase/seed/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.2",
    "p-debounce": "^5.1.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.72.1",
    "react-intersection-observer": "^10.0.3",
    "slugify": "^1.6.9",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@hookform/devtools": "^4.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/config": "^0.1.0",
    "daisyui": "^5.5.19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "supabase": "^2.89.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "type-fest": "^5.5.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
